# ================================================================
# Auto-Trader 환경변수 설정
# 사용법: cp .env.example .env  →  .env 파일을 열어 값 입력
# ⚠️  .env 는 절대 git에 커밋하지 마세요 (.gitignore에 포함됨)
# ================================================================


# ── KIS (한국투자증권) API ───────────────────────────────────────
# 발급: https://apiportal.koreainvestment.com → [개발자센터] → [앱 등록]
# ⚠️  모의투자 / 실전투자 APP KEY 는 별도 앱을 등록해야 합니다
KIS_APP_KEY=여기에_앱키_입력
KIS_APP_SECRET=여기에_앱시크릿_입력

# 계좌번호: 대시(-) 없이 숫자 8자리만 입력
# 예) 500-12-345678 → 50012345
KIS_ACCT_STOCK=계좌번호8자리
KIS_ACCT_OVRS=해외계좌번호8자리   # 해외주식 계좌가 없으면 위와 동일값

KIS_HTS_ID=HTS로그인아이디

# 모의투자: true / 실전투자: false (반드시 true 로 시작하세요)
KIS_IS_PAPER=true


# ── Anthropic Claude API ────────────────────────────────────────
# 발급: https://console.anthropic.com → [API Keys] → [Create Key]
ANTHROPIC_API_KEY=sk-ant-여기에_api키_입력


# ── 텔레그램 알림 (선택, 강력 권장) ────────────────────────────
# 설정 방법:
#   1. 텔레그램에서 @BotFather 검색 → /newbot → 토큰 발급
#   2. 만든 봇에게 아무 메시지 전송 (먼저 해야 chat_id 조회 가능)
#   3. 브라우저에서 아래 URL 열어 chat_id 확인:
#      https://api.telegram.org/bot<TOKEN>/getUpdates
#      응답 JSON의 "chat": {"id": 숫자} 가 CHAT_ID
# 비워두면 알림 없이 정상 실행됩니다
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# ── profit-board 수익 인증 (선택) ──────────────────────────────
# profit-board 에서 회원가입 후 발급받은 값을 입력하세요
# 미설정 시 인증 기능 없이 정상 실행됩니다
VERIFY_ENDPOINT=https://your-profit-board.com
VERIFY_SECRET=
VERIFY_USER_ID=


# ── profit-board 제어판 연동 (선택) ────────────────────────────
# python control.py 실행 시 사용할 설정
# profit-board의 CONTROL_SECRET과 동일하게 설정하세요
CONTROL_PORT=5001
CONTROL_SECRET=


# ── DART 공시 봇 (dart_bot.py 전용) ───────────────────────────
# https://opendart.fss.or.kr 에서 무료 발급 (하루 10만 건)
DART_API_KEY=
DART_BOT_TOKEN=      # BotFather에서 별도 봇 생성
DART_CHAT_ID=
DART_AUTO_BUY_AMOUNT=100000   # 공시 자동매수 금액 (원)


# ── 급등 알림 봇 (surge_alert.py 전용, 기존 봇과 별개) ────────
# BotFather에서 별도 봇 생성 후 입력 (기존 TELEGRAM_BOT_TOKEN과 다른 봇)
SURGE_BOT_TOKEN=
SURGE_CHAT_ID=
# 임계값 조정 (선택)
# SURGE_VOL_RATIO=3.0      # 거래량 평균 대비 배수 (기본 3.0x)
# SURGE_VOL_AVG_DAYS=20    # 거래량 평균 산정 기간 (기본 20일)
# SURGE_BB_SQUEEZE=0.03    # BB 스퀴즈 판단 밴드폭/가격 비율 (기본 3%)
# SURGE_COOLDOWN_MIN=120   # 같은 종목 재알림 방지 시간(분, 기본 120)


# ── 실전 전환 시에만 추가 ───────────────────────────────────────
# KIS_IS_PAPER=false 로 변경한 뒤 아래 줄도 함께 주석 해제해야 실행됩니다
# 둘 중 하나라도 없으면 프로그램이 즉시 종료됩니다 (이중 잠금)
# LIVE_TRADING_CONFIRMED=yes
